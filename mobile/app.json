{
  "expo": {
    "name": "Fluxo de Caixa",
    "slug": "fluxo-caixa-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.distribuidora.fluxocaixa",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Desbloqueie o app com Face ID ao abrir.",
        "NSMicrophoneUsageDescription": "Grave mensagens de voz no chat da equipe."
      }
    },
    "android": {
      "package": "com.distribuidora.fluxocaixa",
      "permissions": ["RECORD_AUDIO", "USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "assetBundlePatterns": ["**/*"]
  }
}
